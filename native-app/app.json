{
  "expo": {
    "name": "RentEx",
    "slug": "rentex",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "rentex",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "app.rentex.mobile",
      "infoPlist": {
        "NSCameraUsageDescription": "RentEx benötigt Kamerazugriff, um QR-Codes zu scannen.",
        "NSFaceIDUsageDescription": "Mit Face ID entsperren Sie die App schneller.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "app.rentex.mobile",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "CAMERA",
        "USE_BIOMETRIC",
        "USE_FINGERPRINT",
        "VIBRATE"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "RentEx benötigt Kamerazugriff, um QR-Codes zu scannen."
        }
      ],
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Mit Face ID entsperren Sie die App schneller."
        }
      ],
      "expo-notifications"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
