generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Car {
  id                    Int                 @id @default(autoincrement())
  brand                 String
  model                 String
  plate                 String              @unique
  year                  Int
  color                 String
  fuelType              String
  transmission          String?
  category              String?
  doors                 Int?
  seats                 Int?
  engineSize            String?
  horsePower            Int?
  fuelConsumption       String?
  co2Emission           String?
  status                String
  vin                   String?             @unique
  chassisNumber         String?
  dailyRate             Decimal
  weeklyRate            Decimal?
  monthlyRate           Decimal?
  longTermRate          Decimal?
  minDaysForLongTerm    Int?
  depositAmount         Decimal?
  promoPrice            Decimal?
  promoStartDate        DateTime?
  promoEndDate          DateTime?
  insuranceCompany      String?
  insurancePolicyNumber String?
  insuranceValidUntil   DateTime?
  registrationDate      DateTime?
  nextInspection        DateTime?
  currentMileage        Int?
  purchaseMileage       Int?
  maxMileagePerDay      Int?
  imageUrl              String?
  images                String?
  description           String?
  features              String?
  hasAirConditioning    Boolean             @default(false)
  hasGPS                Boolean             @default(false)
  hasHeatedSeats        Boolean             @default(false)
  hasParkingSensors     Boolean             @default(false)
  hasBackupCamera       Boolean             @default(false)
  hasCruiseControl      Boolean             @default(false)
  hasBluetoothAudio     Boolean             @default(false)
  hasUSBPorts           Boolean             @default(false)
  hasChildSeatAnchors   Boolean             @default(false)
  hasSkiRack            Boolean             @default(false)
  hasTowHitch           Boolean             @default(false)
  vignetteValidUntil    DateTime?
  vignetteType          String?
  lastOilChange         DateTime?
  nextOilChange         DateTime?
  lastTireChange        DateTime?
  tireType              String?
  nextServiceDate       DateTime?
  lastServiceDate       DateTime?
  locationId            Int?
  homeLocationId        Int?
  purchasePrice         Decimal?
  purchaseDate          DateTime?
  currentValue          Decimal?
  internalNotes         String?
  damageHistory         String?
  isActive              Boolean             @default(true)
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  latitude              Float?
  longitude             Float?
  checkInTemplate       String?
  nextServiceKm         Int?
  homeLocation          Location?           @relation("CarHomeLocation", fields: [homeLocationId], references: [id])
  currentLocation       Location?           @relation("CarLocation", fields: [locationId], references: [id])
  cartSessions          CartSession[]
  damageRecords         DamageRecord[]
  fahrtenbuchEntries    FahrtenbuchEntry[]
  maintenanceRecords    MaintenanceRecord[]
  options               Option[]
  rentals               Rental[]
  strafzettels          StrafzettelRecord[]
  tasks                 Task[]

  @@index([status])
  @@index([locationId])
  @@index([category])
}

model CarCategory {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
}

model Location {
  id            Int      @id @default(autoincrement())
  name          String
  code          String?  @unique
  address       String?
  city          String?
  country       String?  @default("Österreich")
  phone         String?
  email         String?
  latitude      Float?
  longitude     Float?
  openingTime   String?
  closingTime   String?
  isOpenSundays Boolean  @default(false)
  status        String   @default("active")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  homeCars      Car[]    @relation("CarHomeLocation")
  cars          Car[]    @relation("CarLocation")
  pickups       Rental[] @relation("PickupLocation")
  returns       Rental[] @relation("ReturnLocation")
  staff         Staff[]
}

model DamageRecord {
  id                     Int       @id @default(autoincrement())
  carId                  Int
  rentalId               Int?
  type                   String
  description            String?
  severity               String?
  photoUrl               String?
  locationOnCar          String?
  xPosition              Float?
  yPosition              Float?
  reportedDate           DateTime  @default(now())
  status                 String    @default("open")
  repairCost             Decimal?
  accidentCountry        String?   @default("Österreich")
  accidentDate           DateTime?
  accidentPlace          String?
  accidentTime           String?
  circumstances          String?
  injuries               Boolean?  @default(false)
  otherPartyAddress      String?
  otherPartyDamage       String?
  otherPartyDriverName   String?
  otherPartyInsurance    String?
  otherPartyPhone        String?
  otherPartyPolicyNumber String?
  otherPartyRegistration String?
  otherPartyVehicle      String?
  reportedByCustomerId   Int?
  sketchNotes            String?
  witnessAddress         String?
  witnessName            String?
  witnessPhone           String?
  accidentReportUrl      String?
  driverAddress          String?
  driverLicense          String?
  driverName             String?
  photos                 String?
  sketchUrl              String?
  vin                    String?
  car                    Car       @relation(fields: [carId], references: [id])
  rental                 Rental?   @relation(fields: [rentalId], references: [id])
  reportedByCustomer     Customer? @relation(fields: [reportedByCustomerId], references: [id])

  @@index([carId])
  @@index([rentalId])
  @@index([status])
}

/// Finanzamt: Fahrtenbuch pro Fahrzeug (Dienst-/Privatfahrten)
model FahrtenbuchEntry {
  id         Int      @id @default(autoincrement())
  carId      Int
  rentalId   Int?
  datum      DateTime
  startKm    Int
  endKm      Int
  zweck      String
  fahrtzweck String?
  createdAt  DateTime @default(now())
  car        Car      @relation(fields: [carId], references: [id])
  rental     Rental?  @relation(fields: [rentalId], references: [id])

  @@index([carId, datum])
}

model DiscountCoupon {
  id             Int       @id @default(autoincrement())
  code           String    @unique
  description    String?
  discountType   String
  discountValue  Decimal
  validFrom      DateTime?
  validUntil     DateTime?
  minOrderAmount Decimal?
  usageLimit     Int?
  usedCount      Int       @default(0)
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  customerId     Int?
  isPersonal     Boolean   @default(false)
  triggerType    String?
}

model Task {
  id           Int       @id @default(autoincrement())
  title        String
  description  String?
  priority     String    @default("medium")
  status       String    @default("todo")
  dueDate      DateTime?
  assignedTo   String?
  relatedCarId Int?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  car          Car?      @relation(fields: [relatedCarId], references: [id])

  @@index([status])
  @@index([assignedTo])
  @@index([relatedCarId])
  @@index([dueDate])
}

model OptionGroup {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  options     Option[]
}

model Option {
  id          Int            @id @default(autoincrement())
  name        String
  description String?
  price       Decimal
  type        String?
  isPerDay    Boolean        @default(false)
  maxPrice    Decimal?
  maxDays     Int?
  isMandatory Boolean        @default(false)
  maxQuantity Int            @default(1)
  status      String         @default("active")
  imageUrl    String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  carCategory String?
  groupId     Int?
  carId       Int?
  car         Car?           @relation(fields: [carId], references: [id], onDelete: Cascade)
  group       OptionGroup?   @relation(fields: [groupId], references: [id])
  rentals     RentalOption[]
}

model Customer {
  id                    Int             @id @default(autoincrement())
  firstName             String
  lastName              String
  email                 String          @unique
  phone                 String?
  address               String?
  city                  String?
  postalCode            String?
  country               String?         @default("Österreich")
  idType                String?
  idNumber              String?
  licenseNumber         String?
  licenseIssueDate      DateTime?
  licenseExpiryDate     DateTime?
  dateOfBirth           DateTime?
  nationality           String?
  company               String?
  taxId                 String?
  isBlacklisted         Boolean         @default(false)
  blacklistReason       String?
  customerType          String?
  notes                 String?
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
  passwordHash          String?
  agbAcceptedAt         DateTime?
  agbAcceptedVersion    String?
  gdprConsentDate       DateTime?
  gdprConsentVersion    String?
  gdprDeleteRequestedAt DateTime?
  idAustriaVerified     Boolean?        @default(false)
  idAustriaVerifiedAt   DateTime?
  isEuResident          Boolean?        @default(true)
  nonEuApprovedAt       DateTime?
  nonEuApprovedBy       String?
  referralCode          String?         @unique
  referredById          Int?
  idPhotoUrl            String?
  licensePhotoUrl       String?
  isActive              Boolean         @default(true)
  damageReports         DamageRecord[]
  kmBalance             KmBalance?
  kmTransfersFrom       KmTransfer[]    @relation("KmTransferFrom")
  kmTransfersTo         KmTransfer[]    @relation("KmTransferTo")
  pushTokens            PushToken[]
  referralReceived      ReferralBonus[] @relation("ReferralTo")
  referralsSent         ReferralBonus[] @relation("ReferralFrom")
  rentals               Rental[]

  @@index([referredById])
  @@index([isBlacklisted])
}

model Rental {
  id                  Int                 @id @default(autoincrement())
  carId               Int
  customerId          Int
  startDate           DateTime
  endDate             DateTime
  actualReturnDate    DateTime?
  pickupLocationId    Int?
  returnLocationId    Int?
  pickupMileage       Int?
  returnMileage       Int?
  dailyRate           Decimal
  totalDays           Int
  totalAmount         Decimal
  depositPaid         Decimal?
  depositReturned     Decimal?
  extraCharges        Decimal?            @default(0)
  extraChargesNote    String?
  discountAmount      Decimal?            @default(0)
  discountReason      String?
  insuranceType       String?
  insuranceCost       Decimal?
  hasGPS              Boolean             @default(false)
  hasChildSeat        Boolean             @default(false)
  hasSkiRack          Boolean             @default(false)
  extrasCost          Decimal?            @default(0)
  fuelLevelPickup     String?
  fuelLevelReturn     String?
  fuelCharge          Decimal?            @default(0)
  paymentStatus       String
  paymentMethod       String?
  status              String
  contractNumber      String?             @unique
  notes               String?
  damageReport        String?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  stripeSessionId     String?             @unique
  checkInAt           DateTime?
  signature           String?
  fuelPhoto           String?
  mileagePhoto        String?
  checkoutCompletedAt DateTime?
  checkoutPhotos      String?
  isOverdue           Boolean             @default(false)
  mahnung1SentAt      DateTime?
  mahnung2SentAt      DateTime?
  mahnung3SentAt      DateTime?
  returnPhotos        String?
  includedKm          Int?                @default(0)
  driverLicense       String?
  driverName          String?
  damageRecords       DamageRecord[]
  fahrtenbuchEntries  FahrtenbuchEntry[]
  invoices            Invoice?
  mahnungen           MahnungRecord[]
  payments            Payment[]
  car                 Car                 @relation(fields: [carId], references: [id])
  customer            Customer            @relation(fields: [customerId], references: [id])
  pickupLocation      Location?           @relation("PickupLocation", fields: [pickupLocationId], references: [id])
  returnLocation      Location?           @relation("ReturnLocation", fields: [returnLocationId], references: [id])
  options             RentalOption[]
  strafzettels        StrafzettelRecord[]

  @@index([carId])
  @@index([customerId])
  @@index([status])
  @@index([paymentStatus])
  @@index([startDate, endDate])
  @@index([isOverdue])
}

/// Rechnung pro Miete; Registrierkassa / Finanzamt (Österreich)
model Invoice {
  id                        Int       @id @default(autoincrement())
  rentalId                  Int       @unique
  invoiceNumber             String    @unique
  issuedAt                  DateTime  @default(now())
  subtotal                  Decimal
  taxRate                   Decimal   @default(20)
  taxAmount                 Decimal
  total                     Decimal
  status                    String    @default("ISSUED")
  pdfPath                   String?
  registrierkassaExportedAt DateTime?
  registrierkassaBelegId    String?
  createdAt                 DateTime  @default(now())
  customerCountry           String?
  vatRegion                 String?
  rental                    Rental    @relation(fields: [rentalId], references: [id])
}

model Payment {
  id            Int      @id @default(autoincrement())
  rentalId      Int
  amount        Decimal
  paymentMethod String
  paymentDate   DateTime @default(now())
  transactionId String?
  notes         String?
  createdAt     DateTime @default(now())
  rental        Rental   @relation(fields: [rentalId], references: [id])

  @@index([rentalId])
  @@index([paymentDate])
  @@index([transactionId])
}

model MaintenanceRecord {
  id              Int       @id @default(autoincrement())
  carId           Int
  maintenanceType String
  description     String
  cost            Decimal?
  mileage         Int?
  performedBy     String?
  performedDate   DateTime
  nextDueDate     DateTime?
  nextDueMileage  Int?
  invoiceNumber   String?
  notes           String?
  createdAt       DateTime  @default(now())
  invoiceUrl      String?
  car             Car       @relation(fields: [carId], references: [id])

  @@index([carId])
  @@index([nextDueDate])
}

model Notification {
  id           Int       @id @default(autoincrement())
  type         String
  recipient    String
  subject      String?
  message      String
  status       String
  sentAt       DateTime?
  errorMessage String?
  relatedType  String?
  relatedId    Int?
  createdAt    DateTime  @default(now())

  @@index([status, createdAt])
  @@index([relatedType, relatedId])
}

model ActivityLog {
  id          Int      @id @default(autoincrement())
  userId      String?
  userName    String?
  action      String
  entityType  String
  entityId    Int?
  description String
  metadata    String?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())

  @@index([entityType, entityId])
  @@index([userId])
  @@index([createdAt])
}

model SystemSettings {
  id          Int      @id @default(autoincrement())
  key         String   @unique
  value       String
  description String?
  category    String?
  updatedAt   DateTime @updatedAt
  updatedBy   String?
}

model Staff {
  id                   Int         @id @default(autoincrement())
  name                 String
  email                String      @unique
  role                 String
  locationId           Int?
  isActive             Boolean     @default(true)
  passwordHash         String
  lastLoginAt          DateTime?
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt
  twoFactorBackupCodes String?
  twoFactorEnabled     Boolean     @default(false)
  twoFactorSecret      String?
  twoFactorVerifiedAt  DateTime?
  pushTokens           PushToken[]
  location             Location?   @relation(fields: [locationId], references: [id])
}

model PushToken {
  id         Int       @id @default(autoincrement())
  token      String    @unique
  platform   String
  customerId Int?
  staffId    Int?
  createdAt  DateTime  @default(now())
  lastSeenAt DateTime  @updatedAt
  customer   Customer? @relation(fields: [customerId], references: [id], onDelete: Cascade)
  staff      Staff?    @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@index([staffId])
}

model CartSession {
  id         String    @id @default(cuid())
  carId      Int
  sessionKey String    @unique
  expiresAt  DateTime
  startDate  DateTime?
  endDate    DateTime?
  options    String?
  guestEmail String?
  customerId Int?
  createdAt  DateTime  @default(now())
  car        Car       @relation(fields: [carId], references: [id], onDelete: Cascade)

  @@index([expiresAt])
  @@index([carId])
}

model KmBalance {
  id         Int      @id @default(autoincrement())
  customerId Int      @unique
  balance    Int      @default(0)
  updatedAt  DateTime @updatedAt
  customer   Customer @relation(fields: [customerId], references: [id])
}

model KmTransfer {
  id        Int      @id @default(autoincrement())
  fromId    Int
  toId      Int
  amount    Int
  note      String?
  createdAt DateTime @default(now())
  from      Customer @relation("KmTransferFrom", fields: [fromId], references: [id])
  to        Customer @relation("KmTransferTo", fields: [toId], references: [id])
}

model ReferralBonus {
  id               Int      @id @default(autoincrement())
  referrerId       Int
  referredId       Int
  bonusType        String
  bonusValue       Decimal
  status           String   @default("PENDING")
  referralRentalId Int?
  createdAt        DateTime @default(now())
  referred         Customer @relation("ReferralTo", fields: [referredId], references: [id])
  referrer         Customer @relation("ReferralFrom", fields: [referrerId], references: [id])
}

model AgbVersion {
  id          Int       @id @default(autoincrement())
  version     String    @unique
  content     String
  publishedAt DateTime  @default(now())
  notifiedAt  DateTime?
  isActive    Boolean   @default(false)
  createdAt   DateTime  @default(now())
}

model StrafzettelRecord {
  id                    Int       @id @default(autoincrement())
  carId                 Int
  rentalId              Int?
  plate                 String
  issuedDate            DateTime
  issuedTime            String?
  incidentLocation      String?
  amount                Decimal?
  authority             String?
  referenceNumber       String?
  status                String    @default("OPEN")
  forwardedToCustomerAt DateTime?
  paidAt                DateTime?
  paidBy                String?
  notes                 String?
  documentUrl           String?
  createdAt             DateTime  @default(now())
  car                   Car       @relation(fields: [carId], references: [id])
  rental                Rental?   @relation(fields: [rentalId], references: [id])

  @@index([carId])
  @@index([rentalId])
  @@index([status])
}

model AmtlicheAnfrage {
  id           Int       @id @default(autoincrement())
  carId        Int?
  rentalId     Int?
  authority    String
  requestDate  DateTime
  incidentDate DateTime?
  description  String
  responseNote String?
  respondedAt  DateTime?
  status       String    @default("PENDING")
  documentUrl  String?
  createdAt    DateTime  @default(now())
}

model MahnungRecord {
  id       Int      @id @default(autoincrement())
  rentalId Int
  level    Int
  sentAt   DateTime @default(now())
  amount   Decimal
  dueDate  DateTime
  notes    String?
  rental   Rental   @relation(fields: [rentalId], references: [id])

  @@index([rentalId])
}

model RentalOption {
  id        Int      @id @default(autoincrement())
  rentalId  Int
  optionId  Int
  createdAt DateTime @default(now())
  option    Option   @relation(fields: [optionId], references: [id])
  rental    Rental   @relation(fields: [rentalId], references: [id])

  @@index([rentalId])
  @@index([optionId])
}

model CompetitorCompany {
  id               Int               @id @default(autoincrement())
  name             String            @unique
  website          String?
  logo             String?
  notes            String?
  isActive         Boolean           @default(true)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  competitorPrices CompetitorPrice[]
}

model CompetitorPrice {
  id           Int               @id @default(autoincrement())
  dailyRate    Decimal
  brand        String
  competitorId Int
  model        String
  monthlyRate  Decimal?
  notes        String?
  recordedAt   DateTime          @default(now())
  weeklyRate   Decimal?
  competitor   CompetitorCompany @relation(fields: [competitorId], references: [id], onDelete: Cascade)

  @@unique([competitorId, brand, model, recordedAt])
}

model Country {
  id        Int     @id @default(autoincrement())
  iso       String  @db.Char(2)
  name      String  @db.VarChar(80)
  nicename  String  @db.VarChar(80)
  iso3      String? @db.Char(3)
  numcode   Int?
  phonecode Int
}
